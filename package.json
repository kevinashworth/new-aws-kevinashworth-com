{
  "name": "kevinashworth.com",
  "version": "2.3.5",
  "private": true,
  "description": "My website, as powered by Astro",
  "type": "module",
  "scripts": {
    "dev": "astro dev --host",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check:astro": "astro check",
    "check:spell": "npx cspell --config .cspell.json --no-progress --show-suggestions --relative .",
    "check:types": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "npm run format:oxc",
    "fmt:check": "npm run format:oxc:check",
    "format": "npm run format:oxc && npm run format:prettier",
    "format:check": "npm run format:oxc:check && npm run format:prettier:check",
    "format:oxc": "oxfmt --ignore-path .gitignore .",
    "format:oxc:check": "oxfmt --check --ignore-path .gitignore .",
    "format:prettier": "prettier --write .",
    "format:prettier:check": "prettier --check ."
  },
  "dependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/react": "5.0.4",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "3.7.2",
    "@fontsource-variable/inter": "5.2.8",
    "astro": "6.2.1",
    "astro-icon": "1.1.5",
    "astro-pagefind": "1.8.6",
    "limax": "4.2.3",
    "lodash.merge": "4.6.2",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tippy.js": "6.3.7",
    "unpic": "4.2.2"
  },
  "devDependencies": {
    "@astrojs/mdx": "5.0.4",
    "@iconify-json/tabler": "1.2.33",
    "@shikijs/transformers": "4.0.2",
    "@tailwindcss/forms": "0.5.11",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.2.4",
    "@types/js-yaml": "4.0.9",
    "@types/lodash.merge": "4.6.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "js-yaml": "4.1.1",
    "mdast-util-to-string": "4.0.0",
    "oxfmt": "0.47.0",
    "oxlint": "1.62.0",
    "prettier": "3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "reading-time": "1.5.0",
    "sass": "1.99.0",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=18.14.1"
  }
}
