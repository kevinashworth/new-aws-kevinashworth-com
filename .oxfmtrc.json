{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "semi": true,
  "singleQuote": false,
  "tabWidth": 2,
  "trailingComma": "all",
  "useTabs": false,
  "sortTailwindcss": {},
  "sortPackageJson": false,
  "ignorePatterns": [
    "dist",
    "node_modules",
    ".github",
    ".changeset",
    ".oxlintrc.json",
    ".oxfmtrc.json",
    "package.json",
    "public/_hidden/**/*"
  ]
}
